# ── Polymarket Auth ─────────────────────────────────────────
# Your Polygon EOA private key (must hold a Polymarket proxy wallet).
POLY_PRIVATE_KEY=
# Polymarket proxy/funder wallet address that holds USDC collateral.
POLY_FUNDER=
# Optional: explicit CLOB API credentials. If blank, they will be derived
# from POLY_PRIVATE_KEY at startup (IP-bound).
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com

# ── Leader to Copy ─────────────────────────────────────────
# The Polymarket wallet (proxy address) we're monitoring.
COPY_TARGET_ADDRESS=

# ── Sizing ─────────────────────────────────────────────────
# fixed_notional - spend COPY_FIXED_NOTIONAL_USD per copy signal (default)
# proportional   - scale by (your usdc balance / leader portfolio value)
# fixed_ratio    - copy leader's share size * COPY_FIXED_RATIO
# fixed_size     - always trade COPY_FIXED_SIZE shares per signal
COPY_SCALING_MODE=fixed_notional
COPY_FIXED_NOTIONAL_USD=25.0
COPY_FIXED_RATIO=0.05
COPY_FIXED_SIZE=10.0

# ── Risk Guards ────────────────────────────────────────────
# Max USD per single order (0 disables).
COPY_MAX_TRADE_USD=50.0
# Rolling 24h USD spend cap (0 disables).
COPY_MAX_DAILY_USD=500.0
# Rolling 24h trade count cap.
COPY_MAX_DAILY_TRADES=100
# Ignore signals whose dollar size is below this.
COPY_MIN_TRADE_USD=1.0
# Cap total USDC value held in open shares per outcome token (0 disables).
COPY_MAX_POSITION_USD=200.0
# Skip BUYs when leader's fill price exceeds this. Markets clearing at 0.99
# offer max +1c upside vs. -99c downside — fatal asymmetry at small sizes.
# Set to 1.0 to disable the guard.
COPY_MAX_ENTRY_PRICE=0.95

# ── Execution ──────────────────────────────────────────────
# Main loop poll interval (seconds). Short markets resolve fast; 2-3s is good.
COPY_POLL_INTERVAL=3.0
# Aggressive price offset from best quote for FAK orders (basis points of $1).
# 100 = 1 cent on a $1 probability, i.e. 0.01 price ticks. Plenty to get a fill.
COPY_SLIPPAGE_BPS=100
# If true, mirror the leader's SELL orders in tokens we also hold.
COPY_MIRROR_CLOSES=true

# ── Market Filter ──────────────────────────────────────────
# crypto_short - only BTC/ETH 5m & 15m markets (default, matches your use case)
# crypto_any   - any recognised crypto (BTC/ETH/SOL/XRP/DOGE/HYPE/ADA/AVAX/
#                LINK/LTC/DOT/SHIB/MATIC/TRX), any timeframe
# all          - copy every market the leader trades
COPY_MARKET_FILTER=crypto_short
# Extra slug substrings to always allow (comma-separated).
COPY_EXTRA_ALLOW_SLUGS=
# Slug substrings to always block (comma-separated).
COPY_EXTRA_BLOCK_SLUGS=

# ── Startup Behavior ───────────────────────────────────────
# If true, on first start we process activity from the last persisted cursor.
# If false (default), we start fresh from "now" and ignore past trades.
COPY_RESUME_FROM_CURSOR=false

# ── Safety ─────────────────────────────────────────────────
# SAFE DEFAULT - set to false to allow live orders.
COPY_DRY_RUN=true

# ── Logging ────────────────────────────────────────────────
COPY_LOG_LEVEL=INFO
